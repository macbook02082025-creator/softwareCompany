---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import Background from '../components/Background.astro';
import Preloader from '../components/Preloader.astro';
import Cursor from '../components/Cursor.astro';
import CommandPalette from '../components/CommandPalette.astro';
import WorkModal from '../components/WorkModal.astro';
import FloatingUI from '../components/FloatingUI.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Navbar from '../components/Navbar.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
    <Background />
    <Preloader />
    <Cursor />
    <CommandPalette />
    <WorkModal />
    <FloatingUI />
    <MobileMenu />
    
    <Navbar />
    <main>
        <FAQ />
        <CTA />
    </main>
    <Footer />
</BaseLayout>

<script>
const rvObs=new IntersectionObserver(entries=>entries.forEach(e=>{
    if(e.isIntersecting) e.target.classList.add('in');
}),{threshold:.07});
document.querySelectorAll('.rv').forEach(r=>rvObs.observe(r));
</script>
