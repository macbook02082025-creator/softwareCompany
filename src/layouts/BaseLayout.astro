---
const { title = "NEXUS — Engineered for the Future" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Sora:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet"/>
    <!-- Link CSS directly from public to ensure it ALWAYS loads regardless of depth or bundling -->
    <link rel="stylesheet" href="/global.css" />
</head>
<body>
    <slot />
    <script is:inline>
        // Use a more standard Astro script block for better bundling
        const rvObs = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) e.target.classList.add('in');
            });
        }, { threshold: 0.07 });

        const observe = () => {
            document.querySelectorAll('.rv').forEach(r => rvObs.observe(r));
        };

        observe();

        // Re-observe if components are added (useful for some Astro setups)
        const observer = new MutationObserver(observe);
        observer.observe(document.body, { childList: true, subtree: true });
    </script>
</body>
</html>
