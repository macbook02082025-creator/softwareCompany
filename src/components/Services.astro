---
---
<!-- SERVICES BENTO -->
<section class="sec svc-bg" id="services">
  <div class="si">
    <div class="svc-hdr rv">
      <div>
        <div class="ey">Our Expertise</div>
        <h2 class="st">ENGINEERING <span class="ac">CAPABILITIES</span></h2>
      </div>
      <p class="svc-desc-txt">We don't just build features; we architect scalable ecosystems that drive competitive advantage through technical excellence.</p>
    </div>

    <div class="bento-grid">
      <!-- MAIN SERVICE -->
      <div class="bento-card rv" style="grid-column: span 8; grid-row: span 2;">
        <div class="ffront-ico" style="background:rgba(0,255,209,0.1); color:var(--c1);">
          <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        </div>
        <h3 class="ffront-h" style="font-size: 2rem;">Custom Software Engineering</h3>
        <p class="ffront-p" style="font-size: 1rem; max-width: 80%;">End-to-end development of high-performance applications. We specialize in complex architectures, distributed systems, and real-time data processing that remains robust at any scale.</p>
        <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <span class="tc-skill">Distributed Systems</span>
          <span class="tc-skill">Microservices</span>
          <span class="tc-skill">Cloud Native</span>
          <span class="tc-skill">Event-Driven</span>
        </div>
        <div class="blob b1" style="width: 300px; height: 300px; opacity: 0.05; right: -50px; bottom: -50px;"></div>
      </div>

      <!-- AI -->
      <div class="bento-card rv d1" style="grid-column: span 4;">
        <div class="ffront-ico" style="background:rgba(107,23,255,0.1); color:var(--c2);">
          <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zM12 12m-3 0a3 3 0 106 0 3 3 0 10-6 0"/></svg>
        </div>
        <h3 class="ffront-h">AI & Machine Learning</h3>
        <p class="ffront-p">Integrating intelligent systems into production workflows. From LLM orchestration to custom CV models.</p>
      </div>

      <!-- DESIGN -->
      <div class="bento-card rv d2" style="grid-column: span 4;">
        <div class="ffront-ico" style="background:rgba(255,31,110,0.1); color:var(--c3);">
          <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 19l7-7 3 3-7 7-3-3zM18 13l-1.5-7.5L4 2l4 12.5L13 18l5-5z"/></svg>
        </div>
        <h3 class="ffront-h">Product Design</h3>
        <p class="ffront-p">Immersive UI/UX that prioritizes user flow and aesthetic precision.</p>
      </div>

      <!-- CLOUD -->
      <div class="bento-card rv d1" style="grid-column: span 4; height: 300px;">
        <div class="ffront-ico" style="background:rgba(27,142,255,0.1); color:var(--c4);">
          <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
        </div>
        <h3 class="ffront-h">Cloud Infrastructure</h3>
        <p class="ffront-p">Scalable, secure, and automated DevOps pipelines for 99.99% uptime.</p>
      </div>

      <!-- ANALYTICS -->
      <div class="bento-card rv d2" style="grid-column: span 8; height: 300px;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <div style="max-width: 50%;">
            <div class="ffront-ico" style="background:rgba(255,209,0,0.1); color:var(--c5);">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <h3 class="ffront-h">Advanced Analytics</h3>
            <p class="ffront-p">Turning raw data into strategic intelligence with real-time processing and visualization.</p>
          </div>
          <div class="cs-chart" style="height: 120px; width: 40%; align-items: flex-end;">
            <div class="cs-bar" style="height: 40%;"></div>
            <div class="cs-bar" style="height: 70%;"></div>
            <div class="cs-bar" style="height: 50%;"></div>
            <div class="cs-bar" style="height: 90%;"></div>
            <div class="cs-bar" style="height: 60%;"></div>
            <div class="cs-bar" style="height: 85%;"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bento-grid {
    margin-top: 4rem;
  }
  @media (max-width: 1024px) {
    .bento-card {
      grid-column: span 12 !important;
      grid-row: span 1 !important;
      height: auto !important;
    }
  }
</style>
