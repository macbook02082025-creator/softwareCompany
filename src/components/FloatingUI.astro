<!-- FLOAT ORB -->
<div id="float-orb">
  <a href="#cta" id="float-orb-btn"><div id="float-orb-ring1"></div><div id="float-orb-ring2"></div>
    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>
  </a>
  <div id="float-orb-tooltip">Start a project ↗</div>
</div>
<div id="cmd-kb-trigger"><span class="kbd">⌘K</span> CMD</div>
<div id="toast"><div class="ldot"></div><span class="toast-msg"></span></div>

<script>
const toastEl=document.getElementById('toast');
let toastTimer: any;

function showToast(msg: string, col: string = '#00FFD1'){
  if (!toastEl) return;
  toastEl.querySelector('.toast-msg')!.textContent=msg;
  (toastEl as HTMLElement).style.borderColor=col+'40';
  toastEl.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>toastEl.classList.remove('show'),3500);
}

// Global click spark/ripple
document.addEventListener('click',e=>{
  const sparkCol='#00FFD1';
  for(let i=0;i<5;i++){setTimeout(()=>{
    const p=document.createElement('div'),ang=Math.random()*Math.PI*2,dist=20+Math.random()*35,sz=6+Math.random()*8;
    p.style.cssText='position:fixed;border-radius:50%;pointer-events:none;z-index:9999;width:'+sz+'px;height:'+sz+'px;background:'+sparkCol+';left:'+e.clientX+'px;top:'+e.clientY+'px;transform:translate(-50%,-50%);animation:sparkFly .8s ease forwards;--tx:'+Math.cos(ang)*dist+'px;--ty:'+Math.sin(ang)*dist+'px;';
    document.body.appendChild(p);setTimeout(()=>p.remove(),800);
  },i*30);}
  const rng=document.createElement('div');rng.className='click-ripple';
  rng.style.cssText='left:'+e.clientX+'px;top:'+e.clientY+'px;width:26px;height:26px;border-color:'+sparkCol+';';
  document.body.appendChild(rng);setTimeout(()=>rng.remove(),700);
});

// Magnetic buttons
function initMagneticButtons() {
    document.querySelectorAll('.pbtn,.gbtn,.bigp,.bigs,.n-cta,.hnav-btn,.price-cta, #float-orb-btn').forEach(btn=>{
    btn.addEventListener('mousemove',(e: any)=>{
        const r=btn.getBoundingClientRect();
        (btn as HTMLElement).style.transform='translate('+((e.clientX-r.left-r.width/2)*0.35).toFixed(1)+'px,'+((e.clientY-r.top-r.height/2)*0.35).toFixed(1)+'px)';
    });
    btn.addEventListener('mouseleave',()=>{ (btn as HTMLElement).style.transform='translate(0,0)';});
    });
}
initMagneticButtons();

// Command palette trigger
document.getElementById('cmd-kb-trigger')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('toggleCmd'));
});

// Toast listener
window.addEventListener('showToast', ((e: CustomEvent) => showToast(e.detail.msg, e.detail.col)) as any);

setTimeout(()=>showToast('⚡ Accepting projects for Q2 2025'),3200);
</script>
