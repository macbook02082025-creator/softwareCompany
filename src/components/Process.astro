<script>
import * as THREE from 'three';

/* PROCESS CANVAS */
(function(){
  const canvas = document.getElementById('pcanvas') as HTMLCanvasElement;
  if(!canvas)return;
  const R=new THREE.WebGLRenderer({canvas,alpha:true,antialias:false});R.setPixelRatio(1);
  const S=new THREE.Scene(),C=new THREE.PerspectiveCamera(50,1,.1,100);C.position.z=7.5;
  const meshes=[
    new THREE.Mesh(new THREE.DodecahedronGeometry(2.2,0),new THREE.MeshBasicMaterial({color:0x00FFD1,wireframe:true,transparent:true,opacity:.32})),
    new THREE.Mesh(new THREE.IcosahedronGeometry(1.55,0),new THREE.MeshBasicMaterial({color:0x6B17FF,wireframe:true,transparent:true,opacity:.26})),
    new THREE.Mesh(new THREE.OctahedronGeometry(1,0),new THREE.MeshBasicMaterial({color:0xFF1F6E,wireframe:true,transparent:true,opacity:.22}))
  ];
  meshes.forEach(m=>S.add(m));
  function resize(){const w=canvas.parentElement?.clientWidth||420;R.setSize(w,w);C.aspect=1;C.updateProjectionMatrix();}
  window.addEventListener('resize',resize,{passive:true});resize();
  let t=0;(function loop(){requestAnimationFrame(loop);t+=.006;meshes[0].rotation.y=t*.38;meshes[0].rotation.x=t*.19;meshes[1].rotation.y=-t*.55;meshes[1].rotation.z=t*.33;meshes[2].rotation.x=t*.75;meshes[2].rotation.y=t*.52;R.render(S,C);})();
})();
</script>
