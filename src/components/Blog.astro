<script>
function hexToRgb(hex: string){return[parseInt(hex.slice(1,3),16),parseInt(hex.slice(3,5),16),parseInt(hex.slice(5,7),16)];}

function mkBlogCanvas(id: string,c1: string,c2: string){
  const cv = document.getElementById(id) as HTMLCanvasElement;
  if(!cv)return;
  function init(){
    const w=cv.offsetWidth||380,h=cv.offsetHeight||180;cv.width=w;cv.height=h;
    const ctx=cv.getContext('2d');
    if (!ctx) return;
    const gr=ctx.createLinearGradient(0,0,w,h);gr.addColorStop(0,c1+'20');gr.addColorStop(1,c2+'10');
    const nd=Array.from({length:20},()=>({x:Math.random()*w,y:Math.random()*h,vx:(Math.random()-.5)*.28,vy:(Math.random()-.5)*.28,s:Math.random()*1.2+.35}));
    const [r,g,b]=hexToRgb(c1);
    function draw(){
      if (!ctx) return;
      ctx.clearRect(0,0,w,h);ctx.fillStyle=gr;ctx.fillRect(0,0,w,h);
      nd.forEach(n=>{n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>w)n.vx*=-1;if(n.y<0||n.y>h)n.vy*=-1;});
      for(let i=0;i<nd.length;i++)for(let j=i+1;j<nd.length;j++){const ex=nd[i].x-nd[j].x,ey=nd[i].y-nd[j].y,d=Math.sqrt(ex*ex+ey*ey);if(d<88){ctx.beginPath();ctx.strokeStyle='rgba('+r+','+g+','+b+','+(1-d/88)*.16+')';ctx.lineWidth=.4;ctx.moveTo(nd[i].x,nd[i].y);ctx.lineTo(nd[j].x,nd[j].y);ctx.stroke();}}
      nd.forEach(n=>{ctx.beginPath();ctx.arc(n.x,n.y,n.s,0,Math.PI*2);ctx.fillStyle='rgba('+r+','+g+','+b+',.5)';ctx.fill();});
      requestAnimationFrame(draw);
    }
    draw();
  }
  if(cv.offsetWidth>0)init();else setTimeout(init,600);
}

setTimeout(()=>{
    mkBlogCanvas('bcc1','#00FFD1','#1B8EFF');
    mkBlogCanvas('bcc2','#1B8EFF','#6B17FF');
    mkBlogCanvas('bcc3','#6B17FF','#FF1F6E');
},1200);
</script>
