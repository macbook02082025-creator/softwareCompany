<style>
  #nav {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: 1400px;
    z-index: 1000;
    height: 64px;
    border-radius: 32px;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    transition: all 0.6s var(--expo);
  }
  #nav.solid {
    top: 0;
    width: 100%;
    max-width: none;
    border-radius: 0;
    height: 70px;
    background: rgba(2, 2, 5, 0.8);
  }
  .nav-container {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .n-logo {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 0.3em;
    color: #fff;
    text-decoration: none;
    font-family: var(--fd);
  }
  .n-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  @media (max-width: 900px) {
    .n-links, .n-right .n-cta { display: none; }
    #nav { width: 95%; padding: 0 1.5rem; }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) nav?.classList.add('solid');
    else nav?.classList.remove('solid');
  }, { passive: true });

  // Text scramble effect for logo
  const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
  const logo = document.querySelector(".n-logo") as HTMLElement;
  
  if (logo) {
    logo.onmouseover = event => {
      let iteration = 0;
      let interval = setInterval(() => {
        (event.target as HTMLElement).innerText = (event.target as HTMLElement).innerText
          .split("")
          .map((letter, index) => {
            if(index < iteration) {
              return (event.target as HTMLElement).dataset.value![index];
            }
            return letters[Math.floor(Math.random() * 26)]
          })
          .join("");
        
        if(iteration >= (event.target as HTMLElement).dataset.value!.length){ 
          clearInterval(interval);
        }
        iteration += 1 / 3;
      }, 30);
    }
  }
</script>
