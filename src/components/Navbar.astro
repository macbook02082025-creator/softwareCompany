<nav id="nav" class="glass-panel">
  <div class="nav-container">
    <a href="/" class="n-logo" data-value="NEXUS">NEXUS</a>
    <ul class="n-links">
      <li><a href="/services" data-astro-reload>Services</a></li>
      <li><a href="/about" data-astro-reload>About</a></li>
      <li><a href="/portfolio" data-astro-reload>Portfolio</a></li>
      <li><a href="/blog" data-astro-reload>Blog</a></li>
      <li><a href="/careers" data-astro-reload>Careers</a></li>
    </ul>
    <div class="n-right">
      <button class="n-cmd-btn" id="n-search-btn">
        <span class="kbd">⌘</span>
        <span class="kbd">K</span>
      </button>
      <a href="#cta" class="n-cta"><span>Initiate ↗</span></a>
    </div>
