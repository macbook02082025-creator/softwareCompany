        <div class="os-repo-stats">
          <span class="os-stat"><svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>1.9k</span>
          <span class="os-stat"><svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M5.559 8.855c.166 1.06.546 2.058 1.112 2.94L3 16l4.204-1.12A8 8 0 1016 4.5"/></svg>344</span>
