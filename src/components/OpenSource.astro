    <div class="contrib-section rv">
      <div class="contrib-label">GitHub contribution activity — last 12 months</div>
      <div class="contrib-grid" id="contrib-grid"></div>
    </div>
    <div class="os-stats-row">
      <div class="os-big-stat rv"><div class="os-big-val" data-target="12000" data-suffix="+">0</div><div class="os-big-lbl">GitHub Stars</div></div>
      <div class="os-big-stat rv d1"><div class="os-big-val" data-target="2306" data-suffix="">0</div><div class="os-big-lbl">Forks</div></div>
      <div class="os-big-stat rv d2"><div class="os-big-val" data-target="40" data-suffix="k+">0</div><div class="os-big-lbl">Developers Using</div></div>
      <div class="os-big-stat rv d3"><div class="os-big-val" data-target="148" data-suffix="">0</div><div class="os-big-lbl">Contributors</div></div>
    </div>
  </div>
</section>

<script>
(function(){
  const grid=document.getElementById('contrib-grid'); if(!grid)return;
  const levels=['','l1','l2','l3','l4'];
  const weights=[0.3,0.25,0.22,0.15,0.08];
  const days=53*7;
  let html='';
  for(let i=0;i<days;i++){
    const r=Math.random();
    let lvl=0;
    let acc=0;
    for(let j=0;j<weights.length;j++){acc+=weights[j];if(r<acc){lvl=j;break;}}
    const cls='contrib-day'+(levels[lvl]?' '+levels[lvl]:'');
    html+='<div class="'+cls+'" title="'+Math.floor(lvl*Math.random()*8)+' contributions"></div>';
  }
  grid.innerHTML=html;

  // OS stats countup
  new IntersectionObserver(entries=>entries.forEach(e=>{
    if(e.isIntersecting)e.target.querySelectorAll('[data-target]').forEach((n: any)=>{
      const dur=2000,start=performance.now(),target=+n.dataset.target,suf=n.dataset.suffix||'';
      (function step(now){const t=Math.min((now-start)/dur,1),ease=1-Math.pow(2,-10*t);n.textContent=Math.round(ease*target)+suf;if(t<1)requestAnimationFrame(step);})(start);
      delete n.dataset.target;
    });
  }),{threshold:.3}).observe(document.getElementById('opensource')!);
})();
</script>
