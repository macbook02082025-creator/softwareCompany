<!-- OPEN SOURCE -->
<section class="sec" id="opensource">
  <div class="si">
    <div class="ey rv">Community</div>
    <h2 class="st rv">OPEN <span class="ac">SOURCE</span></h2>
    <p class="sec-sub rv" style="color:var(--muted);max-width:560px;line-height:1.8;font-size:.95rem;">We give back to the ecosystem that built us. Our tools are used by 40,000+ developers worldwide.</p>
    <div class="os-grid">
      <div class="os-repo rv">
        <div class="os-repo-top"><span class="os-repo-name">⬡ nexus-infra-sdk</span><span class="os-repo-lang">TypeScript</span></div>
        <p class="os-repo-desc">Infrastructure-as-code SDK for multi-cloud Kubernetes deployments. Zero-config progressive delivery with built-in observability hooks.</p>
        <div class="os-repo-stats">
          <span class="os-stat"><svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>4.2k</span>
          <span class="os-stat"><svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M5.559 8.855c.166 1.06.546 2.058 1.112 2.94L3 16l4.204-1.12A8 8 0 1016 4.5"/></svg>842</span>
          <span class="os-stat">MIT License</span>
        </div>
      </div>
      <div class="os-repo rv d1">
        <div class="os-repo-top"><span class="os-repo-name">⬡ drift-detect</span><span class="os-repo-lang">Python</span></div>
        <p class="os-repo-desc">Production ML model drift detection library. Real-time statistical monitoring with automated retraining triggers and Slack/PagerDuty integrations.</p>
        <div class="os-repo-stats">
          <span class="os-stat"><svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>3.1k</span>
          <span class="os-stat"><svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M5.559 8.855c.166 1.06.546 2.058 1.112 2.94L3 16l4.204-1.12A8 8 0 1016 4.5"/></svg>611</span>
          <span class="os-stat">Apache 2.0</span>
        </div>
      </div>
      <div class="os-repo rv d2">
        <div class="os-repo-top"><span class="os-repo-name">⬡ zero-trust-auth</span><span class="os-repo-lang">Go</span></div>
        <p class="os-repo-desc">Zero-trust authentication middleware for microservices. mTLS, SPIFFE/SPIRE integration, JWT rotation, and real-time policy engine.</p>
        <div class="os-repo-stats">
          <span class="os-stat"><svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>2.8k</span>
