<script>
import * as THREE from 'three';

/* CTA GALAXY */
(function(){
  const canvas = document.getElementById('ccanvas') as HTMLCanvasElement;
  if(!canvas)return;
  const R=new THREE.WebGLRenderer({canvas,alpha:true,antialias:false});R.setPixelRatio(1);
  const S=new THREE.Scene(),C=new THREE.PerspectiveCamera(60,1,.1,200);C.position.z=9;
  function mkG(dir: number){
    const N=1400,pos=new Float32Array(N*3),col=new Float32Array(N*3);
    for(let i=0;i<N;i++){
        const t=i/N,a=t*Math.PI*18*dir,r=t*4+.2+Math.random()*.2;
        pos[i*3]=Math.cos(a)*r;pos[i*3+1]=(Math.random()-.5)*.3;pos[i*3+2]=Math.sin(a)*r;
        col[i*3+1]=t*.85;col[i*3+2]=t*.65+(1-t)*.85;
    }
    const g=new THREE.BufferGeometry();
    g.setAttribute('position',new THREE.BufferAttribute(pos,3));
    g.setAttribute('color',new THREE.BufferAttribute(col,3));
    return new THREE.Points(g,new THREE.PointsMaterial({size:.042,vertexColors:true,transparent:true,opacity:.65}));
  }
  const g1=mkG(1),g2=mkG(-1);g2.rotation.x=Math.PI*.12;S.add(g1,g2);
  S.add(new THREE.Mesh(new THREE.SphereGeometry(.28,10,10),new THREE.MeshBasicMaterial({color:0x00FFD1,transparent:true,opacity:.55})));
  R.setSize(700,700);C.aspect=1;C.updateProjectionMatrix();
  let t=0;(function loop(){requestAnimationFrame(loop);t+=.003;g1.rotation.y=t*.26;g2.rotation.y=Math.PI+t*.26;C.position.x=Math.sin(t*.1)*1.1;C.position.y=Math.cos(t*.08)*.32+.65;C.lookAt(0,0,0);R.render(S,C);})();
})();
</script>
