<!-- MOBILE MENU -->
<div class="mob-menu" id="mob">
  <button class="mob-close" id="mob-close-btn">✕</button>
  <a href="/services" class="mob-link">Services</a>
  <a href="/about" class="mob-link">About</a>
  <a href="/team" class="mob-link">Team</a>
  <a href="/portfolio" class="mob-link">Portfolio</a>
  <a href="/blog" class="mob-link">Blog</a>
  <a href="/careers" class="mob-link">Careers</a>
  <a href="/pricing" class="mob-link">Pricing</a>
  <a href="/faq" class="mob-link">FAQ</a>
</div>

<script>
const mob = document.getElementById('mob');
const mobCloseBtn = document.getElementById('mob-close-btn');
const mobLinks = document.querySelectorAll('.mob-link');

function closeMob(){mob?.classList.remove('open');}

mobCloseBtn?.addEventListener('click', closeMob);
mobLinks.forEach(link => {
    link.addEventListener('click', closeMob);
});

// Listen for global open event
window.addEventListener('openMob', () => {
    mob?.classList.add('open');
});
</script>
